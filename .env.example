# Shopify App credentials (from Shopify Partners dashboard)
SHOPIFY_API_KEY=your_shopify_app_client_id
SHOPIFY_API_SECRET=your_shopify_app_client_secret
SHOPIFY_SCOPES=read_orders,write_returns

# Application URL (your deployed domain, no trailing slash)
APP_URL=https://your-app.up.railway.app
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app

# LLM configuration — supports any OpenAI-compatible provider (OpenRouter, Arouter, etc.)
# If LLM_API_KEY is set it takes priority over OPENAI_API_KEY.
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.arouter.ai/v1
LLM_MODEL=gpt-4o-mini

# Legacy: direct OpenAI key (used if LLM_API_KEY is not set)
OPENAI_API_KEY=sk-your-openai-key

# Session secret for signing cookies and encrypting tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_random_secret_here

# Optional: Sentry DSN for error monitoring (leave empty to disable)
# SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Optional: Resend API key for email notifications (leave empty to disable)
# RESEND_API_KEY=re_your-resend-key
# RESEND_FROM=Auri <notifications@yourdomain.com>
